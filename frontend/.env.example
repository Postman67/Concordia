# Federation API base URL — runtime secret, never sent to the browser.
# Set in Railway → Variables (no redeploy needed, it’s read at server start).
# Can be a full URL or a bare Railway internal hostname (http:// is added automatically):
#   https://your-federation-service.up.railway.app   ← public
#   concordia-federation.railway.internal             ← Railway private network
FEDERATION_BASE_URL=concordia-federation.railway.internal
# Port Federation listens on. Omit if the URL already includes a port or uses the default (80/443).
FEDERATION_PORT=3000

# Token key used in localStorage (baked into the JS bundle, not a secret)
VITE_TOKEN_KEY=concordia_token
